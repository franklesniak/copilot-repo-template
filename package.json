{
  "name": "copilot-repo-template",
  "version": "1.0.0",
  "description": "Template repository with Copilot instructions and code quality tooling",
  "private": true,
  "scripts": {
    "prepare": "husky install || true",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.github/workflows/node_modules\" --config .github/workflows/.markdownlint.jsonc"
  },
  "keywords": [
    "template",
    "copilot",
    "linting"
  ],
  "author": "Frank Lesniak",
  "license": "MIT",
  "devDependencies": {
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.20.0"
  }
}